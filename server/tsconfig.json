{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",

    "types": ["node"],

    "esModuleInterop": true,
    "strict": true,

    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,
    "skipLibCheck": true
  }
}
